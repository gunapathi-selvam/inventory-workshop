# Copy to packages/db/.env and apps/web/.env.local and adjust paths/secrets.

# SQLite now. To move to Postgres later, change packages/db/prisma/schema.prisma
# datasource provider to "postgresql" and set this to a postgres:// URL.
DATABASE_URL="file:C:/New folder/sca1/packages/db/prisma/dev.db"

# Generate a strong value: `openssl rand -base64 32`
AUTH_SECRET="change-me"

APP_URL="http://localhost:3000"

# Email (optional, off by default)
EMAIL_ENABLED="false"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="Workshop <no-reply@workshop.local>"
