# Copy to packages/db/.env and apps/web/.env.local and adjust paths/secrets.

# Postgres. The default below matches the local Docker Postgres in docker-compose.yml
# (`docker compose up -d`). For a hosted DB, paste its postgres:// URL here instead.
# `pnpm run setup:env` writes this into packages/db/.env and apps/web/.env.local for you.
DATABASE_URL="postgresql://workshop:workshop@localhost:5432/workshop?schema=public"

# Generate a strong value: `openssl rand -base64 32`
AUTH_SECRET="change-me"

APP_URL="http://localhost:3000"

# Email (optional, off by default)
EMAIL_ENABLED="false"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_FROM="Workshop <no-reply@workshop.local>"
